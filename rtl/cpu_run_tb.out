 .timescale -9 -12;
TD_cpu_run_tb.print_banner ;
    %vpi_call/w 3 73 "$display", "===========================================" {0 0 0};
    %vpi_call/w 3 74 "$display", "CPU RUN TB: progress marker every %0d cycles", P_0x1257047d0 {0 0 0};
    %vpi_call/w 3 75 "$display", "VCD: dumping ON initially; dumping OFF after %0d finished instructions", P_0x125704750 {0 0 0};
    %vpi_call/w 3 76 "$display", "Markers: 1st fetched 0 => start window, 2nd fetched 0 => endpc; stop at WB_pc==endpc" {0 0 0};
    %vpi_call/w 3 77 "$display", "END: prints CPI + regfile + memory/cache/storebuffer/etc dumps" {0 0 0};
    %vpi_call/w 3 78 "$display", "===========================================" {0 0 0};
    %end;
